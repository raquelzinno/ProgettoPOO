<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.NegozioPrincipale">
  <grid id="27dc6" binding="negozioPanel" custom-create="true" layout-manager="GridLayoutManager" row-count="3" column-count="6" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="0" bottom="10" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
